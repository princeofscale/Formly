# Web Push (VAPID) — generate with: node scripts/generate-vapid.js
# Public key goes to NEXT_PUBLIC_VAPID_PUBLIC_KEY (client-side accessible)
# Private key stays server-side as VAPID_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# Vercel Cron secret — auto-sent as Authorization: Bearer <CRON_SECRET>
# by Vercel for /api/cron/* endpoints. Generate any random string.
CRON_SECRET=
