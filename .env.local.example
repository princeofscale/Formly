# Copy this file to .env.local and fill in the values.
# cp .env.local.example .env.local

# Supabase project: TrainingAR (uxgjsdnpsybnwxkvfxna)
# Dashboard: https://supabase.com/dashboard/project/uxgjsdnpsybnwxkvfxna

NEXT_PUBLIC_SUPABASE_URL=https://uxgjsdnpsybnwxkvfxna.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_Xw-MOvQDm_utIdEB7_pwGA_EVqcNiDt

# Get from: Supabase Dashboard → Project Settings → API → service_role (secret key)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mistral AI — get key from https://console.mistral.ai
# Used for AI training recommendations
MISTRAL_API_KEY=your-mistral-key-here

# Web Push (VAPID) — generate with: node scripts/generate-vapid.js
# Public key goes to NEXT_PUBLIC_VAPID_PUBLIC_KEY (client-side accessible)
# Private key stays server-side as VAPID_PRIVATE_KEY
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com

# Vercel Cron secret — auto-sent as Authorization: Bearer <CRON_SECRET>
# by Vercel for /api/cron/* endpoints. Generate any random string.
CRON_SECRET=
